# ── Semantic Scholar（主数据源，必填）────────────────────────────────
# 申请：https://www.semanticscholar.org/product/api#api-key-form
SEMANTIC_SCHOLAR_API_KEY=

# ── OpenAI（用于 GPT-4o-mini 生成深度摘要，必填）─────────────────────
# 获取：https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── SMTP 邮件发送（复用 paper_pulse 的通用配置，必填）─────────────────
# 163 邮箱示例：
#   SMTP_HOST=smtp.163.com
#   SMTP_PORT=465
#   SMTP_USER=xxx@163.com
#   SMTP_PASSWORD=<授权码，不是登录密码>
# Gmail 示例：
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=465
#   SMTP_USER=xxx@gmail.com
#   SMTP_PASSWORD=<Google 应用专用密码>
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
# 多收件人用英文逗号分隔
EMAIL_TO=

# ── 微信公众号推送（可选，留空则跳过）────────────────────────────────
# 通过 PushPlus 推送到个人微信：
#   1. 微信扫码关注「pushplus 推送加」公众号
#   2. 登录 https://www.pushplus.plus 获取 token
#   3. 把 token 填到下方
WECHAT_PUSHPLUS_TOKEN=
# 群组编码（一对多推送时填，否则留空）
WECHAT_PUSHPLUS_TOPIC=
# 推送通道：wechat / mail / webhook（默认 wechat，通常无需改）
WECHAT_PUSHPLUS_CHANNEL=

# ── 可选：覆盖默认阈值 ───────────────────────────────────────────────
# 当前选择规则：top_ranked × N（综合分最高）+ 经典轮播 × 1
# 每日挑选的 top_ranked 数量（默认 4，加上 1 篇经典 = 每日共 5 篇）
VLA_TOP_RANKED_COUNT=4
# top_ranked 的最低综合分门槛（默认 2.0；设 0 彻底关闭该卫兵）
VLA_TOP_RANKED_MIN_SCORE=2.0

# ── Legacy（老的三段配方，现在未启用；保留兼容性以便以后切回）────────
# VLA_LATEST_HOT_DAYS=90
# VLA_LATEST_HOT_MIN_SCORE=4.0
# VLA_TOP_CITED_MIN_RELEVANCE=5.0
